    {\pagestyle{fancy}% emptyでも可能
        \if@twoside
        \ifodd\c@page
        \hbox{}%
        \vspace*{\fill}%
        \thispagestyle{fancy}% emptyでも可能
        \newpage
        \if@twocolumn
            \hbox{}%
            \newpage
        \fi
        \fi
    \fi
}
}
