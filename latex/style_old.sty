%section subsection書式設定
\newcounter{sectionNewLine}

\titleformat{\section}[display]{\fontsize{11.34pt}{0.0mm}\junM\center}{}{0pt}{\begin{sectionbox}}[\end{sectionbox} \setcounter{sectionNewLine}{1}]

\renewcommand{\subsection}[1]{
    \stepcounter{subsection}
    \ifthenelse{\value{sectionNewLine}=2}{\vspace{3mm}}{}
    \begin{itemize}[nosep,leftmargin=1.5em,labelwidth=1em,labelsep=0.5em]
        \item[\color{darkgray}●]\textsf{#1}
    \end{itemize}
    \setcounter{sectionNewLine}{2}\par
}

\renewcommand{\subsubsection}[1]{
    \stepcounter{subsubsection}
    \ifthenelse{\value{sectionNewLine}=2}{\vspace{3mm}}{}
    \par
    \begin{itemize}[nosep,leftmargin=1em,labelwidth=1em,labelsep=0.0em]
        \item[▶︎] #1
    \end{itemize}
    \setcounter{sectionNewLine}{2} \par
}


%part書式設定
%第1引数: 目次での名前，第2引数: 章見出しでの名前，第3引数: パート画像
\newcommand{\prepart}[3]{
    \begin{partbox}
    % \vspace{-3mm}
        \includegraphics[width=47mm]{#3}
        \tcblower
        \vspace{3mm}
        \fboxrule=0mm
        \addtocounter{part}{1}
        \tcbsubtitle{\fontsize{14.45pt}{0mm}\shingothicB \fbox{\addfontfeatures{RawFeature={+fwid}}\thepart}}
        \addtocounter{part}{-1}
        \fontsize{23.39pt}{4.125mm}\shingothicM\part[#1]{#2}
    \end{partbox}
}
\newcommand{\partset}[3]{
    \begin{figure*}[!t]
        \prepart{#1}{#2}{#3}
    \end{figure*}
}
